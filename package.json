{
  "name": "dicehall",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "next build && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/server.js --external:next --external:express --external:socket.io",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "lint": "next lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@next/eslint-plugin-next": "^15.3.4",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.3.4",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
